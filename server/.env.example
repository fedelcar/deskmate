# OpenWeatherMap API key (free at openweathermap.org)
OWM_API_KEY=your_openweathermap_api_key

# Your location (decimal degrees — find at maps.google.com, right-click your location)
LATITUDE=40.7128
LONGITUDE=-74.0060

# Units: "imperial" (°F) or "metric" (°C)
UNITS=imperial

# iCal calendar URL — get this from:
#   Google Calendar: Settings > [your calendar] > "Secret address in iCal format"
#   iCloud: Calendar app > [right-click calendar] > Share Calendar > public URL
ICAL_URL=https://calendar.google.com/calendar/ical/your-calendar-id/basic.ics

# Server port (ESP32 will connect to this)
PORT=3001
